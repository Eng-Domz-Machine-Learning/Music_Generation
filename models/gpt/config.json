{
  "data_path": "Music_Generation/final_tokenized_data/dataset.jsonl",
  "out_dir": "models/gpt",
  "val_ratio": 0.03,
  "test_ratio": 0.03,
  "vocab_size": 288,
  "max_seq_len": 256,
  "d_model": 512,
  "n_layers": 8,
  "n_heads": 8,
  "d_ff": 2048,
  "dropout": 0.1,
  "batch_size": 16,
  "max_steps": 24000,
  "grad_accum_steps": 1,
  "lr": 0.0006,
  "min_lr": 6e-05,
  "warmup_steps": 1200,
  "weight_decay": 0.1,
  "grad_clip": 1.0,
  "eval_every": 500,
  "eval_batches": 25,
  "save_every": 1000,
  "log_every": 50,
  "early_stop_patience": 12,
  "early_stop_min_delta": 0.0001,
  "seed": 42
}