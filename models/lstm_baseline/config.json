{
  "data_path": "tokenized/dataset.jsonl",
  "out_dir": "models/lstm_baseline",
  "val_ratio": 0.03,
  "test_ratio": 0.03,
  "vocab_size": 288,
  "embed_dim": 256,
  "hidden_size": 512,
  "num_layers": 2,
  "dropout": 0.2,
  "context_len": 256,
  "stride": 128,
  "batch_size": 32,
  "max_steps": 15000,
  "grad_accum_steps": 1,
  "lr": 0.0003,
  "min_lr": 3e-05,
  "warmup_steps": 500,
  "weight_decay": 0.01,
  "grad_clip": 1.0,
  "eval_every": 500,
  "eval_batches": 30,
  "save_every": 1000,
  "log_every": 50,
  "early_stop_patience": 15,
  "early_stop_min_delta": 0.0001,
  "seed": 42
}